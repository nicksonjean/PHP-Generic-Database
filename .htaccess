IndexIgnore *.stub.php composer.* php*.xml grumphp.* phpstan.* doctum.php docker-compose.yml /trash /vendor /assets /cache /resources /scripts /tests /src /bin /docker /adminer /patches /.devcontainer /.stub favicon.ico *.md *.sh *.bat *.mmd
<FilesMatch "^\.">
Order allow,deny
Deny from all
</FilesMatch>
