{
    # Configurações globais do Caddy
    auto_https off
    admin localhost:2019
}

:80 {
    # Servidor HTTP na porta 80
    root * /var/www/html
    encode zstd gzip
    
    # Bloquear acesso direto a arquivos e diretórios que não devem ser exibidos
    @blocked {
        path_regexp ^/(\.|vendor|cache|assets|resources|bin|docker|adminer|patches|trash|\.devcontainer|\.stub|\.git|\.env|\.cursor|\.idea|\.phpunit\.cache|\.qodo|\.stubs|\.vscode)/|^/(composer\.(json|lock)|phpcs\.xml|phpunit\.xml|phpmd\.xml|phpstan\.neon|grumphp\.yml|doctum\.php|docker-compose\.yml|favicon\.ico|\.htaccess|.*\.(stub\.php|md|sh|bat|mmd))$|^/\.
    }
    handle @blocked {
        respond "Not Found" 404
    }
    
    # Tentar servir index files primeiro (index.php, index.html, index.htm)
    try_files {path} {path}/index.php {path}/index.html {path}/index.htm
    
    # PHP handler via FrankenPHP (processa arquivos .php)
    @php {
        path *.php
    }
    handle @php {
        php_server
    }
    
    # Servir arquivos estáticos e diretórios com listing habilitado
    handle {
        file_server browse {
            # Ocultar TODOS os diretórios EXCETO build, connections, docs, readme, samples
            hide vendor
            hide cache
            hide assets
            hide resources
            hide bin
            hide docker
            hide adminer
            hide patches
            hide trash
            hide .devcontainer
            hide .stub
            hide .git
            hide .env
            hide .cursor
            hide .idea
            hide .phpunit.cache
            hide .qodo
            hide .stubs
            hide .vscode
            
            # Ocultar TODOS os arquivos de configuração
            hide composer.json
            hide composer.lock
            hide phpcs.xml
            hide phpunit.xml
            hide phpmd.xml
            hide phpstan.neon
            hide grumphp.yml
            hide doctum.php
            hide docker-compose.yml
            hide favicon.ico
            hide .htaccess
            hide .env.*
            hide .env.docker
            
            # Ocultar por extensão (EXCETO .php que não está listado)
            hide *.stub.php
            hide *.md
            hide *.sh
            hide *.bat
            hide *.mmd
            hide *.txt
            hide *.json
            hide *.xml
            hide *.yml
            hide *.yaml
            hide *.lock
            hide *.log
            hide *.ini
            hide *.conf
            
            # Ocultar arquivos que começam com ponto
            hide .*
        }
    }
    
    # Logs
    log {
        output stdout
        format console
    }
    
    # Headers de segurança
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
    }
}

localhost:443 {
    # Servidor HTTPS na porta 443 com hostname localhost
    root * /var/www/html
    encode zstd gzip
    
    # Bloquear acesso direto a arquivos e diretórios que não devem ser exibidos
    @blocked {
        path_regexp ^/(\.|vendor|cache|assets|resources|bin|docker|adminer|patches|trash|\.devcontainer|\.stub|\.git|\.env|\.cursor|\.idea|\.phpunit\.cache|\.qodo|\.stubs|\.vscode)/|^/(composer\.(json|lock)|phpcs\.xml|phpunit\.xml|phpmd\.xml|phpstan\.neon|grumphp\.yml|doctum\.php|docker-compose\.yml|favicon\.ico|\.htaccess|.*\.(stub\.php|md|sh|bat|mmd))$|^/\.
    }
    handle @blocked {
        respond "Not Found" 404
    }
    
    # Tentar servir index files primeiro (index.php, index.html, index.htm)
    try_files {path} {path}/index.php {path}/index.html {path}/index.htm
    
    # PHP handler via FrankenPHP (processa arquivos .php)
    @php {
        path *.php
    }
    handle @php {
        php_server
    }
    
    # Servir arquivos estáticos e diretórios com listing habilitado
    handle {
        file_server browse {
            # Ocultar TODOS os diretórios EXCETO build, connections, docs, readme, samples
            hide vendor
            hide cache
            hide assets
            hide resources
            hide bin
            hide docker
            hide adminer
            hide patches
            hide trash
            hide .devcontainer
            hide .stub
            hide .git
            hide .env
            hide .cursor
            hide .idea
            hide .phpunit.cache
            hide .qodo
            hide .stubs
            hide .vscode
            
            # Ocultar TODOS os arquivos de configuração
            hide composer.json
            hide composer.lock
            hide phpcs.xml
            hide phpunit.xml
            hide phpmd.xml
            hide phpstan.neon
            hide grumphp.yml
            hide doctum.php
            hide docker-compose.yml
            hide favicon.ico
            hide .htaccess
            hide .env.*
            hide .env.docker
            
            # Ocultar por extensão (EXCETO .php que não está listado)
            hide *.stub.php
            hide *.md
            hide *.sh
            hide *.bat
            hide *.mmd
            hide *.txt
            hide *.json
            hide *.xml
            hide *.yml
            hide *.yaml
            hide *.lock
            hide *.log
            hide *.ini
            hide *.conf
            
            # Ocultar arquivos que começam com ponto
            hide .*
        }
    }
    
    # TLS - usar internal para desenvolvimento local (certificado auto-assinado)
    tls internal
    
    # Logs
    log {
        output stdout
        format console
    }
    
    # Headers de segurança
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000;"
    }
}
